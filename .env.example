# ─────────────────────────────────────────────────────────────────────────────
# ServiceNow Incident Auto-Router — Environment Variables
# Copy to .env and fill in your values. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── ServiceNow ────────────────────────────────────────────────────────────────
# Your ServiceNow instance URL (no trailing slash)
SNOW_INSTANCE_URL=https://yourinstance.service-now.com

# ServiceNow credentials (basic auth or service account)
SNOW_USERNAME=your_service_account
SNOW_PASSWORD=your_password

# ── PostgreSQL Audit Log ──────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
# Leave blank to disable audit logging (not recommended for production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/autorouter

# ── Application ───────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
