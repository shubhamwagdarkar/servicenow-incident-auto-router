# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Incident Auto-Router — Environment Variables
# Copy to .env and fill in the platform(s) you use. Never commit .env to Git.
# ─────────────────────────────────────────────────────────────────────────────

# ── ServiceNow ────────────────────────────────────────────────────────────────
SNOW_INSTANCE_URL=https://yourinstance.service-now.com
SNOW_USERNAME=your_service_account
SNOW_PASSWORD=your_password

# ── Jira Service Management ───────────────────────────────────────────────────
JIRA_INSTANCE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=admin@yourorg.com
JIRA_API_TOKEN=your_jira_api_token

# ── PagerDuty ─────────────────────────────────────────────────────────────────
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_FROM_EMAIL=oncall@yourorg.com

# ── Ivanti Neurons for ITSM ───────────────────────────────────────────────────
IVANTI_INSTANCE_URL=https://yourorg.ivanticloud.com
IVANTI_API_TOKEN=your_ivanti_api_token

# ── Freshservice ──────────────────────────────────────────────────────────────
FRESHSERVICE_INSTANCE_URL=https://yourorg.freshservice.com
FRESHSERVICE_API_KEY=your_freshservice_api_key

# ── PostgreSQL Audit Log ──────────────────────────────────────────────────────
# Format: postgresql://user:password@host:port/database
# Leave blank to disable audit logging
DATABASE_URL=postgresql://postgres:password@localhost:5432/autorouter

# ── Application ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
